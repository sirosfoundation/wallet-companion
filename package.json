{
  "name": "@sirosfoundation/wallet-companion",
  "version": "0.1.0-beta.6",
  "author": "SIROS Foundation",
  "license": "BSD-2-Clause",
  "description": "A browser extension that enhances web wallets with standards-based credential flows, auto-registration, and protocol-aware routing.",
  "type": "module",
  "private": true,
  "scripts": {
    "watch": "WATCH=true LOG_LEVEL=debug BROWSER=chrome tsx vite.ts",
    "watch:chrome": "WATCH=true LOG_LEVEL=debug BROWSER=chrome tsx vite.ts",
    "watch:firefox": "WATCH=true LOG_LEVEL=debug BROWSER=firefox tsx vite.ts",
    "watch:safari": "WATCH=true LOG_LEVEL=debug BROWSER=safari tsx vite.ts",
    "build": "pnpm build:chrome && pnpm build:firefox && pnpm build:safari",
    "build:chrome": "BROWSER=chrome LOG_LEVEL=info tsx vite.ts",
    "build:firefox": "BROWSER=firefox LOG_LEVEL=info tsx vite.ts",
    "build:safari": "BROWSER=safari LOG_LEVEL=info tsx vite.ts",
    "dev:firefox": "cd firefox && web-ext run",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm build:chrome && pnpm test:e2e",
    "test:server": "tsx tests/support/server.ts",
    "wcc-types": "pnpm --filter @sirosfoundation/wcc-types"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "safari-extension",
    "api-polyfill",
    "webextension"
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@sirosfoundation/browser-log": "0.1.0-beta.4",
    "@sirosfoundation/wcc-types": "workspace:^",
    "lucide": "^1.22.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.2.1",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "web-ext": "^10.4.0",
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "packageManager": "pnpm@10.4.0"
}
