{
  "name": "dc-api-interceptor",
  "version": "1.0.0",
  "description": "Cross-browser extension to intercept DC API calls and provide additional functionality",
  "main": "index.js",
  "scripts": {
    "watch": "BROWSER=chrome vite build --watch",
    "watch:chrome": "BROWSER=chrome vite build --watch",
    "watch:firefox": "BROWSER=firefox vite build --watch",
    "watch:safari": "BROWSER=safari vite build --watch",
    "build": "pnpm build:chrome && pnpm build:firefox && pnpm build:safari",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:safari": "BROWSER=safari vite build",
    "dev:firefox": "cd firefox && web-ext run",
    "package:chrome": "cd dist/chrome && zip -r ../chrome-extension.zip . -x '*.git*' -x 'README.md'",
    "package:firefox": "cd dist/firefox && zip -r ../firefox-extension.xpi . -x '*.git*' -x 'README.md'",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.js",
    "test": "jest",
    "test:unit": "jest tests/*.test.js --testPathIgnorePatterns=integration",
    "test:integration": "jest --config jest.integration.config.js",
    "test:wallet": "jest --config jest.integration.config.js tests/wallet-integration.test.js --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "npm run test:unit && npm run build:chrome && npm run test:integration"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "safari-extension",
    "api-interceptor",
    "webextension"
  ],
  "author": "SIROS Foundation",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/chrome": "^0.1.30",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "babel-jest": "^30.2.0",
    "eslint": "^8.56.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.2.0",
    "puppeteer": "^24.30.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "web-ext": "^7.11.0",
    "ws": "^8.18.3"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "packageManager": "pnpm@10.4.0"
}
