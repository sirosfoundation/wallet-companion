{
	"$schema": "https://unpkg.com/@changesets/config@2.3.0/schema.json",
	"changelog": [
		"@changesets/changelog-github",
		{ "repo": "sirosfoundation/wallet-companion" }
	],
	"commit": ["@changesets/cli/commit", { "skipCI": false }],
	"fixed": [],
	"linked": [],
